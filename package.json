{
  "name": "eventory",
  "version": "1.0.0",
  "description": "Eventory is a personal knowledge and activity tracker designed as a backend-focused side project.",
  "main": "index.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "worker:dev": "tsx watch src/workers/event.worker.ts",
    "cli": "tsx src/cli/cli.ts",
    "frontend:dev": "npm --prefix frontend run dev",
    "frontend:build": "npm --prefix frontend run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/QQ1010/Eventory.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/QQ1010/Eventory/issues"
  },
  "homepage": "https://github.com/QQ1010/Eventory#readme",
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@elastic/elasticsearch": "^8.19.1",
    "bullmq": "^5.74.1",
    "commander": "^14.0.3",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "ioredis": "^5.10.1",
    "mongodb": "^7.1.1"
  }
}
